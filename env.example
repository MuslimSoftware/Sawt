# Sawt Voice Assistant Environment Configuration
# Copy this file to .env and fill in your values

# Required: AI Model Configuration
AI_MODEL=your-model-identifier
AI_API_KEY=your-api-key

# Required: Hugging Face Configuration
HUGGING_FACE_API_TOKEN=your-hugging-face-token
HUGGING_FACE_TRANSCRIPTION_MODEL=your-transcription-model

# Required: Frontend Configuration
NEXT_PUBLIC_BACKEND_WS=ws://localhost:8000/ws
NEXT_PUBLIC_NODE_ENV=development